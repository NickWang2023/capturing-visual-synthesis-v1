# 大模型支持下的动作捕捉与视觉合成系统 V1.0
# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=mocap-system
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mocap_db
DB_USERNAME=mocap_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_POOL_SIZE=10

# ==================== 大模型API配置 ====================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# ==================== VLM模型配置 ====================
SAM_MODEL_PATH=/opt/models/sam_vit_h.pth
SAM_MODEL_TYPE=vit_h
VLM_DEVICE=cuda

# ==================== 存储配置 ====================
# 阿里云OSS
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=mocap-storage
OSS_ACCESS_KEY_ID=your_oss_key_id
OSS_ACCESS_KEY_SECRET=your_oss_key_secret

# 本地存储
LOCAL_STORAGE_PATH=/data/mocap
LOCAL_TEMP_PATH=/tmp/mocap

# ==================== 安全配置 ====================
SECRET_KEY=your_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS配置
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true

# ==================== 监控配置 ====================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=/var/log/mocap/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=30

# ==================== 邮件配置（可选）====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com

# ==================== 其他配置 ====================
# GPU配置
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.8

# 性能配置
MAX_BATCH_SIZE=32
NUM_WORKERS=4
PREFETCH_FACTOR=2
